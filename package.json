{
  "name": "easyevents",
  "type": "module",
  "scripts": {
    "dev": "php -S localhost:8000 -t public",
    "build": "tailwindcss -i ./css/style.css -o ./css/style.css",
    "watch": "tailwindcss -i ./css/style.css -o ./css/style.css --watch",
    "start": "npm run dev && npm run watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "postcss": "^8.5.6"
  },
  "dev": {
    "name": "EasyEvents",
    "version": "1.0.0"
  }
}